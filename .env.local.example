# ── Supabase (required) ──────────────────────────────────────────────────
# Public — safe to expose to the browser. RLS is what actually restricts data.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase's current key format (find it under Project Settings > API Keys
# > Publishable key). Preferred — use this one for new projects.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy equivalent (a JWT starting with "eyJ...") — only needed if your
# project still uses the old key system and doesn't have a publishable key.
# The app reads whichever of these two is present; you don't need both.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never prefix with NEXT_PUBLIC_. Only read inside Route
# Handlers/Server Actions that explicitly need to bypass RLS. Use the
# "Secret key" (sb_secret_...) from the same API Keys page, or the legacy
# service_role key.
SUPABASE_SECRET_KEY=

# ── Reserved for future phases — do not fill in yet ──────────────────────
# All server-only. Add these in Vercel's dashboard (Production/Preview/
# Development scoped) when each integration ships — never commit real values.
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHIPBLU_API_KEY=
# WHATSAPP_BUSINESS_TOKEN=
# META_ADS_ACCESS_TOKEN=
# ANTHROPIC_API_KEY=
